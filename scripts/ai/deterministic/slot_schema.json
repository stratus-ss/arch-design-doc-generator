{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:hld:slot_schema:v1",
  "version": "1.0.0",
  "description": "Strict slot schema for deterministic HLD rendering. All slots that appear in phase templates require an evidence-backed extraction entry.",
  "evidence_model": {
    "description": "Each slot extracted by AI must carry this evidence envelope.",
    "type": "object",
    "required": ["value", "confidence", "evidence_excerpt", "evidence_source"],
    "properties": {
      "value":            { "type": "string", "description": "Extracted value, normalized (no leading/trailing whitespace, no markdown)." },
      "confidence":       { "type": "string", "enum": ["high", "medium", "low"], "description": "high=explicit ADR text, medium=inferred, low=guessed or default." },
      "evidence_excerpt": { "type": "string", "description": "Short verbatim quote (<120 chars) from ADR supporting the value. Empty string if default." },
      "evidence_source":  { "type": "string", "description": "ADR filename (basename only) where evidence was found. 'derived_default' if using a hard-coded default." }
    }
  },
  "slots": {
    "APPROVER":                { "required_for": ["preamble"], "description": "Name of the document approver.", "adr_evidence_hints": ["approver", "sign-off", "approval"], "example": "Jane Smith" },
    "ARCHITECT_LEAD":          { "required_for": ["preamble", "appendix"], "description": "Lead architect name.", "adr_evidence_hints": ["architect lead", "lead architect", "technical lead"], "example": "John Doe" },
    "AUTHOR":                  { "required_for": ["preamble"], "description": "Document author name.", "adr_evidence_hints": ["author", "written by", "prepared by"], "example": "Jane Doe" },
    "API_LATENCY_TARGET":      { "required_for": ["appendix"], "description": "API latency SLA target (ms).", "adr_evidence_hints": ["api latency", "response time", "SLA"], "example": "< 200 ms" },
    "APM_VENDOR":              { "required_for": ["phase2", "appendix"], "description": "Application Performance Monitoring vendor.", "adr_evidence_hints": ["APM", "application performance", "Dynatrace", "Datadog", "New Relic"], "example": "Dynatrace" },
    "AUDIT_PROFILE":           { "required_for": ["phase3", "appendix"], "description": "Security audit/compliance profile applied.", "adr_evidence_hints": ["audit profile", "CIS benchmark", "compliance profile"], "example": "default profile with security review" },
    "AVAILABILITY_TARGET":     { "required_for": ["appendix"], "description": "Overall availability SLA (e.g. 99.9%).", "adr_evidence_hints": ["availability", "uptime", "SLA", "99."], "example": "99.9%" },
    "BACKUP_VENDOR":           { "required_for": ["phase2", "preamble", "appendix"], "description": "Backup/recovery platform vendor.", "adr_evidence_hints": ["backup", "recovery", "Rubrik", "Veeam", "Cohesity"], "example": "Rubrik" },
    "BAKE_PERIOD":             { "required_for": ["phase4"], "description": "Observation/stabilisation window after migration.", "adr_evidence_hints": ["bake period", "observation window", "stabilisation", "holdback"], "example": "1-2 weeks" },
    "BLOCK_CSI_DRIVER":        { "required_for": ["phase2", "appendix"], "description": "CSI driver name for DC/middle-tier block storage (NOT ODF, NOT tier 3 site storage).", "adr_evidence_hints": ["IBM block CSI", "block CSI", "IBM Block", "CSI driver", "FC SAN CSI"], "example": "IBM Block CSI Driver" },
    "BLOCK_SC_NAME":           { "required_for": ["phase2", "appendix"], "description": "StorageClass name for DC/middle-tier block storage (NOT ODF StorageClass, NOT tier 3 site storage).", "adr_evidence_hints": ["ibm-block", "ibm-flashsystem", "block StorageClass", "FC SAN StorageClass"], "example": "ibm-block" },
    "BLOCK_STORAGE_VENDOR":    { "required_for": ["phase2", "preamble", "appendix"], "description": "Block storage vendor for DC/middle-tier clusters ONLY. Tier 3 Site ODF is NOT the answer. Look for enterprise SAN hardware.", "adr_evidence_hints": ["FlashSystem", "IBM FlashSystem", "FC SAN", "Pure Storage", "NetApp", "enterprise block"], "example": "IBM FlashSystem" },
    "BRANCH_COUNT":            { "required_for": ["phase1", "preamble", "appendix"], "description": "Number of tier 3 site/ROBO sites.", "adr_evidence_hints": ["tier 3 site", "ROBO", "remote office", "tier 3 sites"], "example": "~300" },
    "BRANCH_CPU_CORES":        { "required_for": ["appendix"], "description": "CPU cores per tier 3 site node.", "adr_evidence_hints": ["tier 3 site CPU", "cores per node", "tier 3 site hardware specs"], "example": "16" },
    "BRANCH_DATA_DISKS":       { "required_for": ["appendix"], "description": "Number of data disks per tier 3 site node.", "adr_evidence_hints": ["tier 3 site data disk", "disk count"], "example": "2" },
    "BRANCH_EGRESS_STRATEGY":  { "required_for": ["phase3", "appendix"], "description": "How tier 3 site sites handle egress traffic.", "adr_evidence_hints": ["tier 3 site egress", "WAN egress", "firewall", "internet breakout"], "example": "requires workshop confirmation" },
    "BRANCH_HARDWARE":         { "required_for": ["phase1", "preamble", "appendix"], "description": "Tier 3 Site server hardware description.", "adr_evidence_hints": ["tier 3 site hardware", "Cisco Unified Edge", "3-node compact", "tier 3 site platform"], "example": "3-node compact Cisco Unified Edge" },
    "BRANCH_IOPS_TARGET":      { "required_for": ["appendix"], "description": "IOPS target for tier 3 site storage.", "adr_evidence_hints": ["tier 3 site IOPS", "storage performance", "IOPS"], "example": "10,000" },
    "BRANCH_NIC_COUNT":        { "required_for": ["appendix"], "description": "Number of NICs per tier 3 site node.", "adr_evidence_hints": ["NIC", "network interface", "tier 3 site NIC"], "example": "2" },
    "BRANCH_RAM":              { "required_for": ["appendix"], "description": "RAM per tier 3 site node.", "adr_evidence_hints": ["tier 3 site RAM", "tier 3 site memory", "GB RAM"], "example": "256 GB" },
    "BRANCH_STORAGE_CAPACITY": { "required_for": ["phase3", "appendix"], "description": "Storage capacity per tier 3 site cluster.", "adr_evidence_hints": ["tier 3 site storage", "TB", "usable capacity"], "example": "~20 TB" },
    "BRANCH_VNIC_MODEL":       { "required_for": ["phase3", "appendix"], "description": "vNIC model / count baseline for tier 3 site VMs.", "adr_evidence_hints": ["vNIC", "virtual NIC", "tier 3 site vNIC", "network model"], "example": "2-vNIC baseline under validation" },
    "BRANCH_WAN_BW":           { "required_for": ["preamble"], "description": "WAN bandwidth for tier 3 site sites.", "adr_evidence_hints": ["WAN bandwidth", "tier 3 site WAN", "Mbps", "Gbps"], "example": "1 Gbps" },
    "CBT_TARGET_DATE":         { "required_for": ["preamble", "appendix"], "description": "Change Blackout / Freeze target date.", "adr_evidence_hints": ["change freeze", "CBT", "blackout date", "moratorium start"], "example": "Q4 2025" },
    "CHANGE_MANAGER":          { "required_for": ["appendix"], "description": "Change management owner name.", "adr_evidence_hints": ["change manager", "change management", "ITSM owner"], "example": "Alice Johnson" },
    "CISO_OR_DELEGATE":        { "required_for": ["appendix"], "description": "CISO or security delegate name.", "adr_evidence_hints": ["CISO", "security officer", "delegate"], "example": "Bob Williams" },
    "CIS_STANDARD_VERSION":    { "required_for": ["appendix"], "description": "CIS benchmark version applied.", "adr_evidence_hints": ["CIS benchmark", "CIS standard", "CIS v"], "example": "CIS Benchmark v1.4" },
    "CLASSIFICATION":          { "required_for": ["preamble"], "description": "Document classification level.", "adr_evidence_hints": ["classification", "confidential", "restricted", "internal"], "example": "Internal — Confidential" },
    "CLIENT":                  { "required_for": ["phase1", "phase2", "phase3", "phase4", "preamble", "appendix"], "description": "Client short name (from project.yaml client_name).", "adr_evidence_hints": ["client", "customer", "organization"], "example": "ACME Corp" },
    "CLUSTER_COUNT":           { "required_for": ["phase1", "preamble", "appendix"], "description": "Total number of OCP clusters.", "adr_evidence_hints": ["cluster count", "clusters", "number of clusters"], "example": "5" },
    "CONSOLE_ACCESS_NOTES":    { "required_for": ["phase2"], "description": "Notes on console/privileged access policy.", "adr_evidence_hints": ["console access", "privileged access", "bastion", "jump host"], "example": "retained per platform security policy" },
    "CPU_OVERCOMMIT_TARGET":   { "required_for": ["phase2"], "description": "CPU overcommit ratio or target.", "adr_evidence_hints": ["overcommit", "CPU ratio", "vCPU ratio"], "example": "defined in capacity planning" },
    "DATE":                    { "required_for": ["preamble"], "description": "Document date (YYYY-MM-DD or Month YYYY).", "adr_evidence_hints": ["date", "as of", "revision date"], "example": "2025-01-01" },
    "DC_CPU_CORES":            { "required_for": ["appendix"], "description": "CPU cores per DC node.", "adr_evidence_hints": ["DC CPU", "data center node", "cores per host"], "example": "64" },
    "DC_IOPS_TARGET":          { "required_for": ["appendix"], "description": "IOPS target for DC storage.", "adr_evidence_hints": ["DC IOPS", "data center IOPS", "storage IOPS"], "example": "500,000" },
    "DC_RAM":                  { "required_for": ["appendix"], "description": "RAM per DC node.", "adr_evidence_hints": ["DC RAM", "data center memory", "GB RAM per host"], "example": "512 GB" },
    "DESCHEDULER_FINAL_PROFILE": { "required_for": ["phase2"], "description": "Descheduler profile chosen after sandbox validation.", "adr_evidence_hints": ["descheduler", "eviction profile", "pod eviction"], "example": "conservative profile after sandbox validation" },
    "DNS_IPAM_VENDOR":         { "required_for": ["phase2", "appendix"], "description": "DNS/IPAM platform vendor.", "adr_evidence_hints": ["DNS", "IPAM", "Infoblox", "Bluecat"], "example": "Infoblox" },
    "EMERGENCY_CHANGE_PROCESS":{ "required_for": ["appendix"], "description": "Emergency change / break-glass procedure.", "adr_evidence_hints": ["emergency change", "break-glass", "emergency procedure"], "example": "ServiceNow RITM + CISO approval" },
    "FISCAL_YEAR":             { "required_for": ["preamble"], "description": "Fiscal year for the project.", "adr_evidence_hints": ["fiscal year", "FY", "budget year"], "example": "FY2026" },
    "HOLDBACK_DURATION":       { "required_for": ["phase4"], "description": "Holdback / observation duration before decommission.", "adr_evidence_hints": ["holdback", "observation window", "wait period", "bake period"], "example": "risk-based observation window" },
    "HOST_CIDR":               { "required_for": ["appendix"], "description": "Host network CIDR range.", "adr_evidence_hints": ["host CIDR", "host network", "baremetal subnet"], "example": "10.0.0.0/24" },
    "HOST_COUNT":              { "required_for": ["phase1", "preamble", "appendix"], "description": "Total number of physical hosts.", "adr_evidence_hints": ["hosts", "servers", "physical nodes", "bare metal"], "example": "120" },
    "HW_DURATION":             { "required_for": ["appendix"], "description": "Hardware procurement/delivery duration.", "adr_evidence_hints": ["lead time", "hardware duration", "procurement timeline"], "example": "12-16 weeks" },
    "HW_LEAD_TIME":            { "required_for": ["preamble"], "description": "Hardware lead time in weeks/months.", "adr_evidence_hints": ["lead time", "hardware lead", "delivery time"], "example": "14 weeks" },
    "HW_MGMT_PLATFORM":        { "required_for": ["phase2", "preamble", "appendix"], "description": "Hardware management platform.", "adr_evidence_hints": ["hardware management", "Intersight", "iDRAC", "ILO", "BMC"], "example": "Intersight" },
    "HW_MONITORING_VENDOR":    { "required_for": ["phase2", "appendix"], "description": "Hardware monitoring/analytics vendor.", "adr_evidence_hints": ["hardware monitoring", "Virtana", "capacity analytics"], "example": "Virtana" },
    "HW_START":                { "required_for": ["appendix"], "description": "Hardware installation start date.", "adr_evidence_hints": ["hardware start", "racking start", "install begin"], "example": "Q1 2025" },
    "IMAGE_REGISTRY":          { "required_for": ["phase2", "appendix"], "description": "Container image registry platform.", "adr_evidence_hints": ["image registry", "Artifactory", "Quay", "Harbor", "registry"], "example": "Artifactory" },
    "INFRA_PLATFORM":          { "required_for": ["phase4", "appendix"], "description": "Current (source) infrastructure platform being migrated from.", "adr_evidence_hints": ["VMware", "vSphere", "legacy platform", "source platform"], "example": "VMware vSphere" },
    "ITSM_PLATFORM":           { "required_for": ["phase2", "appendix"], "description": "ITSM/ticketing platform.", "adr_evidence_hints": ["ITSM", "ServiceNow", "Jira", "ticketing"], "example": "ServiceNow" },
    "LICENSE_SAVINGS":         { "required_for": ["preamble"], "description": "Expected license cost savings description.", "adr_evidence_hints": ["license savings", "cost reduction", "VMware licensing"], "example": "~$4M annual VMware license elimination" },
    "MIGRATION_ARTIFACT_STORAGE": { "required_for": ["phase4"], "description": "Storage location for migration artifacts.", "adr_evidence_hints": ["artifact storage", "migration artifacts", "SMB share", "NFS"], "example": "ACL-controlled SMB/NFS share" },
    "MIGRATION_LEAD":          { "required_for": ["appendix"], "description": "Migration workstream lead name.", "adr_evidence_hints": ["migration lead", "workstream lead", "migration owner"], "example": "Tom Brown" },
    "MIGRATION_TIME_TARGET":   { "required_for": ["appendix"], "description": "Target duration for the migration phase.", "adr_evidence_hints": ["migration time", "migration target", "wave duration"], "example": "6 months" },
    "MIGRATION_TIMELINE":      { "required_for": ["preamble"], "description": "High-level migration timeline description.", "adr_evidence_hints": ["migration timeline", "project timeline", "go-live"], "example": "18-month phased migration" },
    "MIGRATION_WINDOW":        { "required_for": ["phase4"], "description": "Approved migration maintenance window.", "adr_evidence_hints": ["migration window", "maintenance window", "change window", "PM"], "example": "11 PM – 6 AM, Saturday/Sunday" },
    "MORATORIUM_SCHEDULE":     { "required_for": ["phase4", "preamble", "appendix"], "description": "Change freeze/moratorium schedule.", "adr_evidence_hints": ["moratorium", "change freeze", "blackout", "mid-month", "year-end"], "example": "mid-month and year-end blackouts" },
    "NETWORK_LEAD":            { "required_for": ["preamble"], "description": "Network workstream lead name.", "adr_evidence_hints": ["network lead", "network owner", "networking contact"], "example": "Carol White" },
    "NOC_PLATFORM":            { "required_for": ["phase2", "preamble", "appendix"], "description": "NOC/event management platform.", "adr_evidence_hints": ["NOC", "Moogsoft", "PagerDuty", "event management"], "example": "Moogsoft" },
    "OBJECT_STORAGE":          { "required_for": ["phase2", "preamble", "appendix"], "description": "Object storage platform.", "adr_evidence_hints": ["object storage", "ICOS", "S3", "MinIO", "Ceph"], "example": "ICOS" },
    "OCP_VERSION":             { "required_for": ["phase1", "appendix"], "description": "Target OpenShift version.", "adr_evidence_hints": ["OpenShift version", "OCP version", "4.", "OCP 4"], "example": "4.16" },
    "OS_DISK_CONFIG":          { "required_for": ["appendix"], "description": "OS disk configuration for nodes.", "adr_evidence_hints": ["OS disk", "boot disk", "root disk", "disk layout"], "example": "RAID-1 2x480 GB SSD" },
    "P2_OBS_DURATION":         { "required_for": ["appendix"], "description": "Phase 2 observability setup duration.", "adr_evidence_hints": ["phase 2", "observability duration", "monitoring setup"], "example": "4 weeks" },
    "P2_SEC_DURATION":         { "required_for": ["appendix"], "description": "Phase 2 security hardening duration.", "adr_evidence_hints": ["phase 2", "security duration", "hardening"], "example": "4 weeks" },
    "P2_STOR_DURATION":        { "required_for": ["appendix"], "description": "Phase 2 storage integration duration.", "adr_evidence_hints": ["phase 2", "storage duration", "CSI"], "example": "2 weeks" },
    "P3_ACM_DURATION":         { "required_for": ["appendix"], "description": "Phase 3 ACM/GitOps setup duration.", "adr_evidence_hints": ["phase 3", "ACM", "GitOps", "duration"], "example": "3 weeks" },
    "P3_REM_DURATION":         { "required_for": ["appendix"], "description": "Phase 3 remediation duration.", "adr_evidence_hints": ["phase 3", "remediation", "RHEL", "duration"], "example": "4 weeks" },
    "P3_UPG_DURATION":         { "required_for": ["appendix"], "description": "Phase 3 upgrade/patch duration.", "adr_evidence_hints": ["phase 3", "upgrade", "patch", "duration"], "example": "3 weeks" },
    "P4_DECOM_DURATION":       { "required_for": ["appendix"], "description": "Phase 4 decommission duration.", "adr_evidence_hints": ["decommission", "decom", "phase 4 decom", "duration"], "example": "6 weeks" },
    "P4_PILOT_DURATION":       { "required_for": ["appendix"], "description": "Phase 4 pilot migration duration.", "adr_evidence_hints": ["pilot migration", "phase 4 pilot", "duration"], "example": "4 weeks" },
    "P4_PROD_DURATION":        { "required_for": ["appendix"], "description": "Phase 4 production migration waves duration.", "adr_evidence_hints": ["production migration", "migration waves", "phase 4 prod"], "example": "16 weeks" },
    "PLACEHOLDER":             { "required_for": ["appendix"], "description": "Generic placeholder (appendix boilerplate marker).", "adr_evidence_hints": [], "example": "" },
    "PLACEHOLDERS":            { "required_for": ["preamble"], "description": "Generic placeholders token (preamble boilerplate).", "adr_evidence_hints": [], "example": "" },
    "PM_TOOL":                 { "required_for": ["preamble"], "description": "Project management tool used.", "adr_evidence_hints": ["project management", "PM tool", "Jira", "Confluence", "Smartsheet"], "example": "Jira" },
    "POD_CIDR":                { "required_for": ["phase1"], "description": "Kubernetes Pod CIDR range.", "adr_evidence_hints": ["PodSubnet", "pod CIDR", "cluster CIDR"], "example": "10.128.0.0/14" },
    "PODS_PER_NODE":           { "required_for": ["phase1"], "description": "Max pods per node setting.", "adr_evidence_hints": ["pods per node", "maxPods", "pod density"], "example": "512" },
    "PREREQ_DURATION":         { "required_for": ["appendix"], "description": "Phase 1 prerequisites duration.", "adr_evidence_hints": ["prerequisites", "phase 1", "prep duration"], "example": "4 weeks" },
    "PROD1_DURATION":          { "required_for": ["appendix"], "description": "First production workload onboarding duration.", "adr_evidence_hints": ["production onboarding", "first production", "duration"], "example": "4 weeks" },
    "PROJECT_MANAGER":         { "required_for": ["preamble", "appendix"], "description": "Project manager name.", "adr_evidence_hints": ["project manager", "PM", "program manager"], "example": "Dave Green" },
    "PROMETHEUS_RETENTION_DAYS": { "required_for": ["appendix"], "description": "Prometheus local metrics retention in days.", "adr_evidence_hints": ["Prometheus retention", "metrics retention", "days"], "example": "30" },
    "REGULATORY_FRAMEWORKS":   { "required_for": ["preamble", "appendix"], "description": "Applicable regulatory/compliance frameworks.", "adr_evidence_hints": ["regulatory", "compliance", "FFIEC", "PCI", "SOC", "NIST", "FedRAMP"], "example": "FFIEC, PCI-DSS, SOC 2" },
    "REMEDIATION_OPERATION_MODE": { "required_for": ["phase3"], "description": "Remediation orchestration operation mode.", "adr_evidence_hints": ["remediation", "SNR", "FAR", "EDA", "Ansible", "operation mode"], "example": "SNR to FAR to EDA/Ansible" },
    "REPO_BOUNDARY_DECISION":  { "required_for": ["phase2"], "description": "GitOps repository boundary decision.", "adr_evidence_hints": ["repo boundary", "GitOps", "repository structure", "cluster repo"], "example": "under evaluation" },
    "REVIEWER_LIST":           { "required_for": ["preamble"], "description": "Comma-separated list of document reviewers.", "adr_evidence_hints": ["reviewer", "reviewed by", "review board"], "example": "Alice Smith, Bob Jones" },
    "ROBO_TARGET_DATE":        { "required_for": ["preamble", "appendix"], "description": "ROBO/tier 3 site migration target date.", "adr_evidence_hints": ["ROBO target", "tier 3 site migration date", "remote office timeline"], "example": "Q2 2026" },
    "RPO_BRANCH":              { "required_for": ["appendix"], "description": "RPO for tier 3 site/ROBO sites.", "adr_evidence_hints": ["RPO tier 3 site", "ROBO RPO", "recovery point"], "example": "24 hours" },
    "RPO_REGIONAL":            { "required_for": ["appendix"], "description": "RPO for regional/DR sites.", "adr_evidence_hints": ["RPO regional", "regional RPO", "DR RPO"], "example": "4 hours" },
    "RPO_TARGET":              { "required_for": ["appendix"], "description": "Overall RPO target.", "adr_evidence_hints": ["RPO", "recovery point objective"], "example": "4 hours" },
    "RTO_BRANCH":              { "required_for": ["appendix"], "description": "RTO for tier 3 site/ROBO sites.", "adr_evidence_hints": ["RTO tier 3 site", "ROBO RTO", "recovery time"], "example": "8 hours" },
    "RTO_DC_CRITICAL":         { "required_for": ["appendix"], "description": "RTO for DC critical workloads.", "adr_evidence_hints": ["RTO critical", "DC critical", "recovery time"], "example": "1 hour" },
    "RTO_DC_STANDARD":         { "required_for": ["appendix"], "description": "RTO for DC standard workloads.", "adr_evidence_hints": ["RTO standard", "DC standard", "recovery time"], "example": "4 hours" },
    "RTO_REGIONAL":            { "required_for": ["appendix"], "description": "RTO for regional sites.", "adr_evidence_hints": ["RTO regional", "regional RTO"], "example": "2 hours" },
    "SANDBOX_DURATION":        { "required_for": ["appendix"], "description": "Sandbox/lab phase duration.", "adr_evidence_hints": ["sandbox", "lab phase", "pilot lab", "duration"], "example": "4 weeks" },
    "SCANNING_VENDOR":         { "required_for": ["phase3", "appendix"], "description": "Vulnerability scanning vendor.", "adr_evidence_hints": ["scanning", "vulnerability scan", "Tenable", "Qualys", "Prisma"], "example": "Tenable" },
    "SECRET_MGMT_VENDOR":      { "required_for": ["phase2", "preamble", "appendix"], "description": "Secret / credential management vendor.", "adr_evidence_hints": ["secret management", "vault", "CyberArk", "Conjur", "HashiCorp"], "example": "CyberArk" },
    "SECURITY_LEAD":           { "required_for": ["preamble", "appendix"], "description": "Security workstream lead name.", "adr_evidence_hints": ["security lead", "security owner", "ISSO"], "example": "Eve Davis" },
    "SERVER_HARDWARE":         { "required_for": ["phase1", "preamble", "appendix"], "description": "Server hardware platform (DC nodes).", "adr_evidence_hints": ["server hardware", "Cisco UCS", "Dell PowerEdge", "HPE ProLiant"], "example": "Cisco UCS M7" },
    "SIEM_PLATFORM":           { "required_for": ["phase2", "preamble", "appendix"], "description": "SIEM/log management platform.", "adr_evidence_hints": ["SIEM", "Splunk", "QRadar", "log management"], "example": "Splunk" },
    "SITE_COUNT":              { "required_for": ["phase1", "preamble", "appendix"], "description": "Number of sites (DC + ROBO).", "adr_evidence_hints": ["site count", "number of sites", "locations", "data centers"], "example": "3" },
    "SITE_LAB":                { "required_for": ["phase1"], "description": "Lab/pre-production site name.", "adr_evidence_hints": ["lab site", "pre-prod site", "test site", "SiteLab"], "example": "SiteLab" },
    "SITE_PRIMARY":            { "required_for": ["phase1"], "description": "Primary DC site name.", "adr_evidence_hints": ["primary site", "primary DC", "main data center", "SitePrimary"], "example": "SitePrimary" },
    "SITE_SECONDARY":          { "required_for": ["phase1"], "description": "Secondary DC / DR site name.", "adr_evidence_hints": ["secondary site", "DR site", "secondary DC", "SiteSecondary"], "example": "SiteSecondary" },
    "SPONSOR":                 { "required_for": ["preamble", "appendix"], "description": "Executive sponsor name.", "adr_evidence_hints": ["sponsor", "executive sponsor", "business owner"], "example": "Sarah Connor" },
    "SRE_LEAD":                { "required_for": ["preamble"], "description": "SRE/operations lead name.", "adr_evidence_hints": ["SRE lead", "operations lead", "site reliability"], "example": "Mike Rogers" },
    "STATUS":                  { "required_for": ["appendix"], "description": "Document status (e.g. DRAFT, FINAL).", "adr_evidence_hints": ["status", "document status"], "example": "DRAFT" },
    "STORAGE_LEAD":            { "required_for": ["preamble"], "description": "Storage workstream lead name.", "adr_evidence_hints": ["storage lead", "storage owner"], "example": "Nancy Hall" },
    "SVC_CIDR":                { "required_for": ["phase1"], "description": "Kubernetes Service CIDR range.", "adr_evidence_hints": ["ServicesSubnet", "service CIDR", "svc CIDR", "clusterIP range"], "example": "172.30.0.0/16" },
    "SWITCH_VENDOR":           { "required_for": ["phase1"], "description": "Network switch/fabric vendor.", "adr_evidence_hints": ["switch vendor", "network vendor", "Cisco", "Arista", "Juniper"], "example": "Cisco" },
